# BAC Unified Environment Variables Template
# Copy to .env and fill in actual values

# Database
DATABASE_URL=postgresql://user:password@postgres:5432/bac
POSTGRES_USER=bac
POSTGRES_PASSWORD=<generate_strong_password>
POSTGRES_DB=bac

# Auth
JWT_SECRET=<run: openssl rand -hex 32>

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=<your_bot_token>
ALLOWED_TELEGRAM_USER_ID=<your_telegram_id>

# WhatsApp
ALLOWED_WHATSAPP_NUMBER=<your_whatsapp_number>

# AI Providers
OPENAI_API_KEY=<openai_key>
ANTHROPIC_API_KEY=<anthropic_key>
OLLAMA_URL=http://localhost:11434

# Optional: Cloud databases
TURSO_DB_URL=
REDIS_URL=
