{
  "gateway": {
    "name": "vault-assistant",
    "port": 18789,
    "web_url": "https://vault-openclaw.onrender.com"
  },
  "telegram": {
    "enabled": true,
    "bot_token": "${TELEGRAM_BOT_TOKEN}",
    "allowed_users": []
  },
  "discord": {
    "enabled": false
  },
  "slack": {
    "enabled": false
  },
  "anthropic": {
    "enabled": true,
    "api_key": "${ANTHROPIC_API_KEY}",
    "model": "claude-sonnet-4-20250514"
  },
  "openai": {
    "enabled": false
  },
  "google": {
    "enabled": false
  },
  "openrouter": {
    "enabled": false
  },
  "tools": {
    "exec": {
      "enabled": true,
      "timeout": 120,
      "elevated": false
    },
    "browser": {
      "enabled": false
    },
    "git": {
      "enabled": true,
      "allowed_repos": ["https://github.com/mednou/*"]
    },
    "filesystem": {
      "enabled": true,
      "allowed_dirs": ["/workspace"]
    },
    "http": {
      "enabled": true
    }
  },
  "model": {
    "provider": "anthropic",
    "max_tokens": 32000
  },
  "approval": {
    "enabled": false,
    "elevated": false
  },
  "workspace": {
    "dir": "/workspace"
  },
  "logging": {
    "level": "info"
  }
}
