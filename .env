# Environment Configuration
# Copy this to .env and fill in your values

# Database (use Docker Compose default)
NEON_DB_URL=postgres://bac:bac_password@localhost:5432/bac?sslmode=disable

# Redis (use Docker Compose default)
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=local-dev-secret-change-in-production

# Ollama (optional - install from ollama.ai)
OLLAMA_URL=http://localhost:11434

# Storage (Garage S3) - optional
GARAGE_ENDPOINT=http://localhost:3900
GARAGE_ACCESS_KEY=your-access-key
GARAGE_SECRET_KEY=your-secret-key
GARAGE_BUCKET=bac-storage

# API Keys (Optional - for cloud AI fallback)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Monitoring
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

# Application
PORT=8080
ENV=development
LOG_LEVEL=info

# Features
ENABLE_WEBSOCKET=true
ENABLE_WEBRTC=true
ENABLE_GAMIFICATION=true
