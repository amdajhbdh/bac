# BAC Unified - Environment Variables
# Copy this to .env and fill in your values

# ============================================================================
# Core Services
# ============================================================================

# Gateway (Rust) - Default port 8080
GATEWAY_HOST=127.0.0.1:8080
GATEWAY_URL=http://127.0.0.1:8080

# OCR Service (Rust) - Default port 3000
OCR_SERVICE_URL=http://127.0.0.1:3000
OCR_SERVICE_HOST=127.0.0.1:3000

# Animation Output Directory
ANIMATION_OUTPUT_DIR=/tmp/animations

# ============================================================================
# Database - PostgreSQL + pgvector (Neon)
# ============================================================================

# Primary database connection (Neon)
NEON_DB_URL=postgresql://neondb_owner:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Alternative: Local PostgreSQL
# PGHOST=localhost
# PGPORT=5432
# PGUSER=bac
# PGPASSWORD=your_password
# PGDATABASE=bac

# ============================================================================
# NLM Cache - Turso (SQLite)
# ============================================================================

TURSO_DB_URL=libsql://your-org.turso.io
TURSO_AUTH_TOKEN=your_auth_token

# ============================================================================
# Storage - Garage S3 (Local) or MinIO
# ============================================================================

# Garage S3 (local development)
GARAGE_ENDPOINT=http://localhost:3900
GARAGE_ACCESS_KEY=your_access_key
GARAGE_SECRET_KEY=your_secret_key
GARAGE_BUCKET=bac-resources

# Alternative: MinIO (production)
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=your_access_key
# MINIO_SECRET_KEY=your_secret_key
# MINIO_BUCKET=bac-resources

# ============================================================================
# AI Inference - Ollama
# ============================================================================

# Ollama (local LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Cloud API Fallbacks (if Ollama fails)
# KIMI_API_KEY=your_kimi_key
# DEEPSEEK_API_KEY=your_deepseek_key
# MINIMAX_API_KEY=your_minimax_key

# ============================================================================
# Search - Elasticsearch
# ============================================================================

ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=questions

# ============================================================================
# Redis (Hot Cache)
# ============================================================================

REDIS_URL=redis://localhost:6379

# ============================================================================
# OCR - Optional Cloud Fallbacks
# ============================================================================

# OCR.space (free tier)
OCRSPACE_API_KEY=your_ocrspace_key

# Google Cloud Vision (paid)
VISION_API_KEY=your_vision_api_key

# ============================================================================
# External Services
# ============================================================================

# YouTube DL
YTDLP_PATH=yt-dlp

# NotebookLM CLI
NLM_CLI_PATH=nlm

# ============================================================================
# Development
# ============================================================================

# RUST_LOG=debug
# RUST_BACKTRACE=1
