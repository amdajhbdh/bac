# BAC Study Environment Variables
# Copy this to .env and fill in your values

# ===================
# AI Providers
# ===================

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Yandex
YANDEX_FOLDER_ID=your_folder_id
YANDEX_IAM_TOKEN=your_iam_token

# Google Gemini
GEMINI_API_KEY=your_gemini_key

# Mistral
MISTRAL_API_KEY=your_mistral_key

# ===================
# OCR Providers
# ===================

# ABBYY
ABBYY_APP_ID=your_app_id
ABBYY_PASSWORD=your_password

# Cloudmersive
CLOUDMERSIVE_API_KEY=your_api_key

# OCR API
OCRAPI_KEY=your_ocrapi_key

# ===================
# Database
# ===================

UPSTASH_REST_URL=https://your-db.upstash.io
UPSTASH_REST_TOKEN=your_token

# ===================
# Services
# ===================

# Local OCR Server
OCR_SERVER_URL=http://localhost:8000

# Cloudflare Worker
CLOUDFLARE_WORKER_URL=https://your-worker.workers.dev

# ===================
# RAG Pipeline
# ===================

EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./chroma_db
CACHE_DIR=./cache
DOMAIN_DATA_DIR=./domain_data
