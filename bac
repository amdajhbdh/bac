#!/usr/bin/env python3
"""BAC Unified CLI Entry Point"""

import sys
import subprocess
import os

def main():
    os.chdir(os.path.dirname(os.path.abspath(__file__)))
    
    if len(sys.argv) < 2:
        # Show help
        subprocess.run(["nu", "-c", "source bac.nu; main"])
        return
    
    cmd = sys.argv[1]
    args = sys.argv[2:]
    
    if cmd == "solve":
        if not args:
            print("Usage: bac solve <problem>")
            sys.exit(1)
        problem = " ".join(args)
        # Escape for nushell
        problem = problem.replace('"', '\\"')
        cmd_str = f'source bac.nu; cmd-solve ["{problem}"]'
        subprocess.run(["nu", "-c", cmd_str])
    elif cmd == "predict":
        subprocess.run(["nu", "-c", "source bac.nu; main predict"])
    elif cmd == "practice":
        subprocess.run(["nu", "-c", "source bac.nu; main practice"])
    elif cmd == "stats":
        subprocess.run(["nu", "-c", "source bac.nu; main stats"])
    elif cmd == "test":
        subprocess.run(["nu", "-c", "source bac.nu; main test"])
    else:
        subprocess.run(["nu", "-c", f"source bac.nu; main {cmd}"])

if __name__ == "__main__":
    main()
