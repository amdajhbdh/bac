# flyctl launch added from .gitignore
**/node_modules
**/src/extractor/target
**/target
# Generated by Cargo
# will have compiled files and executables
**/debug
**/target

# These are backup files generated by rustfmt
**/**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
**/*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/**/mutants.out*

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/
# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
**/*.exe
**/*.exe~
**/*.dll
**/*.so
**/*.dylib

# Test binary, built with `go test -c`
**/*.test

# Code coverage profiles and other test artifacts
**/*.out
**/coverage.*
**/*.coverprofile
**/profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
**/go.work
**/go.work.sum

# env file
**/.env

# Editor/IDE
# .idea/
**/.zig-cache
**/zig-out
**/*.o .vscode
**/*.tar.gz

# flyctl launch added from .opencode/.gitignore
.opencode/**/node_modules
.opencode/**/package.json
.opencode/**/bun.lock
.opencode/**/.gitignore

# flyctl launch added from resources/notes/.gitignore
# Obsidian and Smart Connections
resources/notes/**/.obsidian
resources/notes/**/.smart-env

# Python cache
resources/notes/**/__pycache__
resources/notes/**/*.pyc
resources/notes/**/*.pyo

# Temporary files
resources/notes/**/*.tmp
resources/notes/**/*.temp
resources/notes/**/*~

# OS files
resources/notes/**/.DS_Store
resources/notes/**/Thumbs.db

# Databases
resources/notes/**/*.db
resources/notes/**/*.db-journal

# Cache
resources/notes/**/.cache
resources/notes/**/.ruff_cache

# Keep this file
!resources/notes/**/.gitignore

# flyctl launch added from src/kilocode/.gitignore
src/kilocode/**/.husky/_
src/kilocode/**/.DS_Store
src/kilocode/**/node_modules
src/kilocode/**/.worktrees
src/kilocode/**/.sst
src/kilocode/**/.env
src/kilocode/**/.idea
src/kilocode/**/.vscode/*
!src/kilocode/**/.vscode/extensions.json
!src/kilocode/**/.vscode/launch.json
!src/kilocode/**/.vscode/settings.json
!src/kilocode/**/.vscode/tasks.json
# use vscode workspaces with peacock to have many vscodes with the same repo:
src/kilocode/**/*.code-workspace
src/kilocode/**/.codex
src/kilocode/**/*~
src/kilocode/**/playground
src/kilocode/**/tmp
src/kilocode/**/dist
src/kilocode/**/ts-dist
src/kilocode/**/storybook-static
src/kilocode/**/.turbo
src/kilocode/**/**/.serena
src/kilocode/**/.serena
src/kilocode/result
src/kilocode/**/refs
src/kilocode/**/Session.vim
src/kilocode/**/opencode.json
src/kilocode/**/a.out
src/kilocode/**/target
src/kilocode/**/.scripts
src/kilocode/**/.direnv

# Local dev files
src/kilocode/**/opencode-dev
src/kilocode/**/logs
src/kilocode/**/*.bun-build

# Telemetry ID
src/kilocode/**/telemetry-id
src/kilocode/**/tsconfig.tsbuildinfo

# flyctl launch added from src/kilocode/.husky/_/.gitignore
src/kilocode/.husky/_/**/*

# flyctl launch added from src/kilocode/.opencode/.gitignore
src/kilocode/.opencode/**/plans
src/kilocode/.opencode/**/bun.lock
src/kilocode/.opencode/**/package.json

# flyctl launch added from src/kilocode/sdks/vscode/.gitignore
src/kilocode/sdks/vscode/**/dist
fly.toml
